DATABASE_URL="postgresql://hydrateuser:hydratepass@localhost:5433/hydrate_study"
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
PORT=4001
FRONTEND_URL="http://localhost:5173"

# Google OAuth — Web client ID from Google Cloud Console (same value as VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=""

# Generate with: npx web-push generate-vapid-keys
# Never commit real keys. Use NEW keys on Railway (do not reuse local/dev keys).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:you@example.com"
REMINDER_PUSH_CHECK_MS=60000
